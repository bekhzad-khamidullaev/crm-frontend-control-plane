{
  "name": "enterprise_crm",
  "version": "1.0.0",
  "description": "Enterprise CRM - Modern CRM System",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "build:production": "tsc && vite build --mode production",
    "preview": "vite preview",
    "preview:staging": "vite preview --mode staging",
    "preview:production": "vite preview --mode production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier -w .",
    "format:check": "prettier --check .",
    "prepare": "husky install",
    "analyze": "vite build --mode production && open dist/stats.html",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:login": "playwright test login.spec.js",
    "test:e2e:leads": "playwright test leads.spec.js",
    "test:e2e:contacts": "playwright test contacts.spec.js",
    "test:e2e:integration": "playwright test integration.spec.js",
    "codegen": "npx openapi-typescript-codegen --input './openapi-schema.yml' --output src/shared/api/generated --client axios --useOptions --useUnionTypes",
    "sync:backend-api": "cd ../crm-backend && ./.venv/bin/python generate_schema.py ./openapi-schema-new.yml && cd - && cp ../crm-backend/openapi-schema-new.yml ./openapi-schema.yml && npm run codegen",
    "sync:full": "npm run sync:backend-api && npm run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@craftjs/core": "^0.2.12",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-query": "^5.62.12",
    "@tanstack/react-query-devtools": "^5.62.12",
    "@tanstack/react-table": "^8.21.3",
    "antd": "^5.29.3",
    "axios": "^1.13.5",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.19",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jssip": "^3.13.5",
    "lucide-react": "^0.484.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.6",
    "zod": "^3.25.7"
  },
  "overrides": {
    "dompurify": "^3.3.3"
  },
  "lint-staged": {
    "*.{js,jsx,css,html}": [
      "prettier -w",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^20.17.10",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.0",
    "openapi-typescript-codegen": "^0.29.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^1.6.1"
  }
}
