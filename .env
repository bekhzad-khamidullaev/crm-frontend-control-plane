# Production API Configuration
VITE_API_BASE_URL=https://api.crm.windevs.uz
VITE_API_PREFIX=/api
VITE_API_TIMEOUT=30000
VITE_AUTH_MODE=jwt
VITE_API_SEND_COOKIES=false

# Backend API Server
# REST API base should point to your backend origin (usually api.crm.windevs.uz)
# Example: VITE_API_BASE_URL=https://api.crm.windevs.uz

# SIP/WebRTC Configuration for pbx.windevs.uz
VITE_SIP_REALM=pbx.windevs.uz
VITE_SIP_USERNAME=
VITE_SIP_PASSWORD=
VITE_SIP_SERVER=wss://pbx.windevs.uz:5061
VITE_SIP_DISPLAY_NAME=Contora User
VITE_STUN_SERVER=stun:stun.l.google.com:19302

# WebSocket Configuration
# Use the same domain as REST API (VITE_API_BASE_URL) unless your infrastructure proxies WebSockets elsewhere.
# Expected endpoints:
# - wss://api.crm.windevs.uz/ws/calls/
# - wss://api.crm.windevs.uz/ws/chat/
VITE_WS_URL=wss://api.crm.windevs.uz/ws/calls/
VITE_CHAT_WS_URL=wss://api.crm.windevs.uz/ws/chat/

# Environment
NODE_ENV=production
