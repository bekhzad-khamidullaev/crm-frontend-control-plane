# Production API Configuration
VITE_API_BASE_URL=https://api.console.crm.windevs.uz
VITE_API_PREFIX=/api
VITE_API_TIMEOUT=30000
VITE_AUTH_MODE=jwt
VITE_API_SEND_COOKIES=false

# Backend API Server
# REST API base should point to your backend origin (usually api.crm.windevs.uz)
# Example: VITE_API_BASE_URL=https://api.crm.windevs.uz

# SIP/WebRTC Configuration for pbx.windevs.uz
VITE_SIP_REALM=pbx.windevs.uz
VITE_SIP_USERNAME=1001
VITE_SIP_PASSWORD=AdminSIP!2026
VITE_SIP_SERVER=wss://api.console.crm.windevs.uz/asterisk/ws
VITE_SIP_DISPLAY_NAME=Administrator
VITE_STUN_SERVER=stun:stun.l.google.com:19302

# WebSocket Configuration
VITE_WS_URL=wss://api.console.crm.windevs.uz/ws/calls/
VITE_CHAT_WS_URL=wss://api.console.crm.windevs.uz/ws/chat/

# Environment

# Vite controls mode by build command (do not set NODE_ENV here).
CRM_CONTROL_PLANE_FRONTEND_PORT=8082
API_BASE_URL=https://api.console.crm.windevs.uz
API_PREFIX=/api
PBX_SERVER=wss://api.console.crm.windevs.uz/asterisk/ws
