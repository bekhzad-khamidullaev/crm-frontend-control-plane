# Staging API Configuration
VITE_API_BASE_URL=https://staging.crm.windevs.uz
VITE_API_PREFIX=/api
VITE_API_TIMEOUT=30000
VITE_AUTH_MODE=jwt
VITE_API_SEND_COOKIES=false

# SIP/WebRTC Configuration
VITE_SIP_REALM=pbx.windevs.uz
VITE_SIP_USERNAME=
VITE_SIP_PASSWORD=
VITE_SIP_SERVER=wss://pbx.windevs.uz:5061
VITE_SIP_DISPLAY_NAME=CRM User (Staging)
VITE_STUN_SERVER=stun:stun.l.google.com:19302

# WebSocket Configuration
VITE_WS_URL=wss://staging.crm.windevs.uz/ws/calls/
VITE_CHAT_WS_URL=wss://staging.crm.windevs.uz/ws/chat/

# Environment

# Vite controls mode by build command (do not set NODE_ENV here).
VITE_APP_VERSION=
VITE_GIT_COMMIT=
VITE_BUILD_TIMESTAMP=
