================================================================================
⚠️  ACTION REQUIRED BEFORE DEPLOYMENT
================================================================================

ON LOCAL MACHINE:
  1. npm install --save-dev rollup-plugin-visualizer vite-plugin-compression @vitest/coverage-v8
  2. Update SIP credentials in .env.production
  3. npm run build:production
  4. git add . && git commit -m "Production ready" && git push

ON SERVER:
  5. Configure DNS: windevs.uz → server IP
  6. Clone repo to /opt/crm-frontend
  7. sudo ./scripts/setup-server.sh
  8. sudo certbot --nginx -d windevs.uz -d www.windevs.uz
  9. ./deploy.sh production
  10. ./scripts/health-check.sh

