# API Configuration
VITE_API_BASE_URL=https://api.crm.windevs.uz
VITE_API_PREFIX=/api
VITE_API_TIMEOUT=30000
VITE_AUTH_MODE=jwt
VITE_API_SEND_COOKIES=false
VITE_APP_VERSION=
VITE_GIT_COMMIT=
VITE_BUILD_TIMESTAMP=

# License gating UX policy:
# banner -> keep module/page visible and show "not available without license"
# hide   -> fully hide restricted modules/pages from navigation and route access
VITE_LICENSE_ACCESS_POLICY=hide

# SIP/WebRTC Configuration
VITE_SIP_REALM=
VITE_SIP_USERNAME=
VITE_SIP_PASSWORD=
VITE_SIP_SERVER=
VITE_SIP_DISPLAY_NAME=Enterprise CRM User
VITE_STUN_SERVER=stun:stun.l.google.com:19302

# WebSocket Configuration (optional)
# If empty, the app derives WebSocket origin from VITE_API_BASE_URL
# Example:
# VITE_WS_URL=wss://api.crm.windevs.uz/ws/calls/
# VITE_CHAT_WS_URL=wss://api.crm.windevs.uz/ws/chat/
VITE_WS_URL=
VITE_CHAT_WS_URL=

# Docker Compose (production)
CRM_FRONTEND_PORT=8080
API_BASE_URL=https://api.crm.windevs.uz
API_PREFIX=/api
PBX_SERVER=wss://crm.windevs.uz/asterisk/ws
