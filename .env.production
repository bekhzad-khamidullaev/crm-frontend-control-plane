# Production API Configuration
VITE_API_BASE_URL=https://api.crm.windevs.uz
VITE_API_PREFIX=/api
VITE_API_TIMEOUT=30000
VITE_AUTH_MODE=jwt
VITE_API_SEND_COOKIES=false

# Backend API Server (proxied through nginx)
# Direct backend: https://api.crm.windevs.uz:8443
# But frontend calls go through nginx proxy at https://crm.windevs.uz/api/

# SIP/WebRTC Configuration for pbx.windevs.uz
VITE_SIP_REALM=pbx.windevs.uz
VITE_SIP_USERNAME=1001
VITE_SIP_PASSWORD=AdminSIP!2026
VITE_SIP_SERVER=wss://crm.windevs.uz/asterisk/ws
VITE_SIP_DISPLAY_NAME=Administrator
VITE_STUN_SERVER=stun:stun.l.google.com:19302

# WebSocket Configuration (proxied through nginx)
VITE_WS_URL=wss://crm.windevs.uz/ws/calls/
VITE_CHAT_WS_URL=wss://crm.windevs.uz/ws/chat/

# Environment
NODE_ENV=production
